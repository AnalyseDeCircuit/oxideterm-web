---
import Landing from "@/layouts/Landing.astro";
import Hero from "@/components/Hero.astro";
import StatsBanner from "@/components/StatsBanner.astro";
import FeatureCards from "@/components/FeatureCards.astro";
import DemoVideo from "@/components/DemoVideo.astro";
import FeatureDetails from "@/components/FeatureDetails.astro";
import SecuritySection from "@/components/SecuritySection.astro";
import TechHighlights from "@/components/TechHighlights.astro";
import CliSection from "@/components/CliSection.astro";
import CompetitiveTable from "@/components/CompetitiveTable.astro";
import LegalCompliance from "@/components/LegalCompliance.astro";
import DownloadSection from "@/components/DownloadSection.astro";
import Footer from "@/components/Footer.astro";

const lang = "vi";
---

<Landing lang={lang}>
