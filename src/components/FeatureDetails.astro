---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const features = [
  {
    id: "terminal",
    title: i.details.terminal_title,
    items: [i.details.terminal_1, i.details.terminal_2, i.details.terminal_3, i.details.terminal_4, i.details.terminal_5],
    img: "/images/screenshots/terminal.png",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ot-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>`,
  },
  {
    id: "sftp",
    title: i.details.sftp_title,
    items: [i.details.sftp_1, i.details.sftp_2, i.details.sftp_3, i.details.sftp_4],
    img: "/images/screenshots/sftp.png",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ot-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 18v-6"/><path d="M14 18v-3"/></svg>`,
  },
  {
    id: "ide",
    title: i.details.ide_title,
    items: [i.details.ide_1, i.details.ide_2, i.details.ide_3, i.details.ide_4],
    img: "/images/screenshots/ide.png",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ot-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    id: "ai",
    title: i.details.ai_title,
    items: [i.details.ai_1, i.details.ai_2, i.details.ai_3, i.details.ai_4],
    img: "/images/screenshots/ai.gif",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ot-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>`,
  },
  {
    id: "forwarding",
    title: i.details.forwarding_title,
    items: [i.details.forwarding_1, i.details.forwarding_2, i.details.forwarding_3, i.details.forwarding_4],
    img: "/images/screenshots/forwarding.png",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--ot-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
];
---

<section class="py-20 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 tracking-tight">
      {i.details.title}
    </h2>

    <div class="space-y-20">
      {features.map((feature, idx) => (
        <div class:list={[
          "grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center",

        ]}>
          <!-- Text side -->
          <div class={idx % 2 !== 0 ? "lg:order-2" : ""}>
            <div class="flex items-center gap-3 mb-4">
              <span aria-hidden="true" set:html={feature.icon} />
              <h3 class="text-2xl font-bold text-[var(--ot-text-primary)]">
                {feature.title}
              </h3>
            </div>
            <ul class="space-y-3">
              {feature.items.map((item) => (
                <li class="flex items-start gap-3 text-[var(--ot-text-secondary)]">
                  <span class="text-[var(--ot-accent)] mt-1 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Image side -->
          <div class={idx % 2 !== 0 ? "lg:order-1" : ""}>
            <div class="screenshot-frame">
              <img
                src={feature.img}
                alt={feature.title}
                class="w-full h-auto"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
