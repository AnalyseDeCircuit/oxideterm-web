---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";
import { icon } from "@/lib/icons";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const accent = "var(--ot-accent)";
const features = [
  {
    id: "terminal",
    title: i.details.terminal_title,
    items: [i.details.terminal_1, i.details.terminal_2, i.details.terminal_3, i.details.terminal_4, i.details.terminal_5],
    img: "/images/screenshots/terminal.png",
    icon: icon("terminal", { size: 28, stroke: accent }),
  },
  {
    id: "sftp",
    title: i.details.sftp_title,
    items: [i.details.sftp_1, i.details.sftp_2, i.details.sftp_3, i.details.sftp_4],
    img: "/images/screenshots/sftp.png",
    icon: icon("fileChart", { size: 28, stroke: accent }),
  },
  {
    id: "ide",
    title: i.details.ide_title,
    items: [i.details.ide_1, i.details.ide_2, i.details.ide_3, i.details.ide_4],
    img: "/images/screenshots/ide.png",
    icon: icon("code", { size: 28, stroke: accent }),
  },
  {
    id: "ai",
    title: i.details.ai_title,
    items: [i.details.ai_1, i.details.ai_2, i.details.ai_3, i.details.ai_4],
    img: "/images/screenshots/ai.gif",
    icon: icon("bot", { size: 28, stroke: accent }),
  },
  {
    id: "forwarding",
    title: i.details.forwarding_title,
    items: [i.details.forwarding_1, i.details.forwarding_2, i.details.forwarding_3, i.details.forwarding_4],
    img: "/images/screenshots/forwarding.png",
    icon: icon("link", { size: 28, stroke: accent }),
  },
];
---

<section class="py-20 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 tracking-tight">
      {i.details.title}
    </h2>

    <div class="space-y-20">
      {features.map((feature, idx) => (
        <div class:list={[
          "grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center",

        ]}>
          <!-- Text side -->
          <div class={idx % 2 !== 0 ? "lg:order-2" : ""}>
            <div class="flex items-center gap-3 mb-4">
              <span aria-hidden="true" set:html={feature.icon} />
              <h3 class="text-2xl font-bold text-[var(--ot-text-primary)]">
                {feature.title}
              </h3>
            </div>
            <ul class="space-y-3">
              {feature.items.map((item) => (
                <li class="flex items-start gap-3 text-[var(--ot-text-secondary)]">
                  <span class="text-[var(--ot-accent)] mt-1 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Image side -->
          <div class={idx % 2 !== 0 ? "lg:order-1" : ""}>
            <div class="screenshot-frame">
              <img
                src={feature.img}
                alt={feature.title}
                class="w-full h-auto"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
