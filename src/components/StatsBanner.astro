---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const stats = [
  { value: i.stats.binary_value, label: i.stats.binary_size },
  { value: i.stats.themes_value, label: i.stats.themes },
  { value: i.stats.languages_value, label: i.stats.languages_count },
  { value: i.stats.ai_tools_value, label: i.stats.ai_tools },
  { value: i.stats.stores_value, label: i.stats.stores },
  { value: i.stats.zero_c_value, label: i.stats.zero_c },
];
---

<section class="py-10 px-6 bg-[var(--ot-bg-deep)] border-y border-[var(--ot-border)]">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 text-center">
      {stats.map((stat) => (
        <div class="stat-item">
          <div class="text-2xl md:text-3xl font-bold text-[var(--ot-accent)] stat-number">
            {stat.value}
          </div>
          <div class="text-xs text-[var(--ot-text-muted)] mt-1 uppercase tracking-wider">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
