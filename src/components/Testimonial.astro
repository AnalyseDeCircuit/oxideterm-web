---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);
---

<section class="py-16 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-3xl mx-auto text-center">
    <blockquote class="relative">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="36"
        height="36"
        viewBox="0 0 24 24"
        fill="var(--ot-accent)"
        class="mx-auto mb-6 opacity-20"
        aria-hidden="true"
      >
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
      </svg>
      <p class="text-lg md:text-xl text-[var(--ot-text-primary)] leading-relaxed italic mb-6" style="font-family: var(--font-serif);">
        {i.testimonial.quote}
      </p>
      <footer class="flex items-center justify-center gap-3">
        <img
          src="https://github.com/AnalyseDeCircuit.png"
          alt={i.testimonial.name}
          width="40"
          height="40"
          class="rounded-full ring-2 ring-[var(--ot-border)]"
          loading="lazy"
        />
        <div class="text-left">
          <cite class="not-italic text-sm font-semibold text-[var(--ot-text-primary)]">
            {i.testimonial.name}
          </cite>
          <p class="text-xs text-[var(--ot-text-muted)]">
            {i.testimonial.role}
          </p>
        </div>
      </footer>
    </blockquote>
  </div>
</section>
