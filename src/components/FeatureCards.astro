---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const rows = [
  { pain: i.comparison.pain_1, answer: i.comparison.answer_1 },
  { pain: i.comparison.pain_2, answer: i.comparison.answer_2 },
  { pain: i.comparison.pain_3, answer: i.comparison.answer_3 },
  { pain: i.comparison.pain_4, answer: i.comparison.answer_4 },
  { pain: i.comparison.pain_5, answer: i.comparison.answer_5 },
  { pain: i.comparison.pain_6, answer: i.comparison.answer_6 },
  { pain: i.comparison.pain_7, answer: i.comparison.answer_7 },
];
---

<section class="py-20 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-3 tracking-tight">
      {i.comparison.title}
    </h2>
    <p class="text-center text-[var(--ot-text-muted)] mb-12 max-w-xl mx-auto">
      {i.comparison.subtitle}
    </p>

    <!-- Column headers -->
    <div class="hidden sm:grid grid-cols-2 gap-8 pb-3 border-b-2 border-[var(--ot-border)] mb-2">
      <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ot-text-muted)]">
        {i.comparison.label_problem}
      </span>
      <span class="text-xs font-semibold uppercase tracking-wider text-[var(--ot-text-muted)]">
        {i.comparison.label_solution}
      </span>
    </div>

    <!-- Comparison rows -->
    {rows.map((row) => (
      <div class="comparison-row">
        <div class="flex items-baseline gap-3">
          <span class="text-[var(--ot-red)] font-bold text-sm shrink-0" aria-hidden="true">&#10005;</span>
          <span class="text-[var(--ot-text-muted)]">{row.pain}</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="text-[var(--ot-green)] font-bold text-sm shrink-0" aria-hidden="true">&#10003;</span>
          <span class="text-[var(--ot-text-primary)]" set:html={row.answer} />
        </div>
      </div>
    ))}
  </div>
</section>
