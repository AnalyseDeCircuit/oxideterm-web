---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";
import { icon } from "@/lib/icons";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);
const c = i.competitive;

const s = { size: 20 };
const features = [
  { label: c.local_terminal, icon: icon("terminal", s) },
  { label: c.native_size, icon: icon("package", s) },
  { label: c.pure_rust, icon: icon("shield", s) },
  { label: c.builtin_sftp, icon: icon("file", s) },
  { label: c.builtin_ide, icon: icon("code", s) },
  { label: c.ai_assistant, icon: icon("bot", s) },
  { label: c.multiplexing, icon: icon("link", s) },
  { label: c.grace_reconnect, icon: icon("refresh", s) },
  { label: c.plugin_system, icon: icon("wrench", s) },
  { label: c.multi_lang, icon: icon("globe", s) },
  { label: c.source_available, icon: icon("github", s) },
];
---

<section class="py-20 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-3 tracking-tight">
      {c.title}
    </h2>
    <p class="text-center text-[var(--ot-text-muted)] mb-14 max-w-xl mx-auto">
      {c.subtitle}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <div class="flex items-center gap-4 px-5 py-4 rounded-xl border border-[var(--ot-border)] bg-[var(--ot-bg-elevated)] hover:border-[var(--ot-accent)] transition-colors">
          <span class="text-[var(--ot-accent)] shrink-0" aria-hidden="true" set:html={feature.icon} />
          <span class="text-sm font-medium text-[var(--ot-text-primary)]">{feature.label}</span>
          <span class="ml-auto text-[var(--ot-green)] font-bold text-lg" aria-hidden="true">✓</span>
        </div>
      ))}
    </div>
  </div>
</section>
