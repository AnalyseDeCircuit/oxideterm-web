---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";
import { icon } from "@/lib/icons";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const accent = "var(--ot-accent)";
const s = { size: 32, stroke: accent };
const cards = [
  { icon: icon("lock", s), title: i.security.encryption_title, desc: i.security.encryption_desc },
  { icon: icon("filePhoto", s), title: i.security.keychain_title, desc: i.security.keychain_desc },
  { icon: icon("shield", s), title: i.security.ssh_title, desc: i.security.ssh_desc },
  { icon: icon("biometric", s), title: i.security.biometric_title, desc: i.security.biometric_desc },
];
---

<section class="py-20 px-6 bg-[var(--ot-bg-deep)] border-t border-[var(--ot-border)]">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-3 tracking-tight">
      {i.security.title}
    </h2>
    <p class="text-center text-[var(--ot-text-muted)] mb-14 max-w-xl mx-auto">
      {i.security.subtitle}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {cards.map((card) => (
        <div class="card rounded-xl p-8">
          <div class="mb-4" aria-hidden="true" set:html={card.icon} />
          <h3 class="text-lg font-semibold mb-2 text-[var(--ot-text-primary)]">
            {card.title}
          </h3>
          <p class="text-sm text-[var(--ot-text-secondary)] leading-relaxed">
            {card.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
