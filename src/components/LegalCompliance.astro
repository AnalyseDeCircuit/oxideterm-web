---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";
import { icon } from "@/lib/icons";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const accent = "var(--ot-accent)";
const s = { size: 18, stroke: accent };
const sections = [
  { icon: icon("globe", s), title: i.legal.network_title, desc: i.legal.network_desc },
  { icon: icon("bot", s), title: i.legal.ai_title, desc: i.legal.ai_desc },
  { icon: icon("lock", s), title: i.legal.data_title, desc: i.legal.data_desc },
  { icon: icon("scales", s), title: i.legal.license_title, desc: i.legal.license_desc },
];
---

<section class="py-14 px-6 bg-[var(--ot-bg-deep)] border-t border-[var(--ot-border)]">
  <div class="max-w-4xl mx-auto">
    <p class="text-xs font-semibold uppercase tracking-wider text-[var(--ot-accent)] text-center mb-3">
      {i.legal.badge}
    </p>
    <div class="flex items-center justify-center gap-2 mb-2">
      <span aria-hidden="true" set:html={icon("shieldCheck", { size: 22, stroke: accent })} />
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight">
        {i.legal.title}
      </h2>
    </div>
    <p class="text-center text-xs text-[var(--ot-text-muted)] mb-10 max-w-2xl mx-auto">
      {i.legal.subtitle}
    </p>

    <div class="space-y-5">
      {sections.map((section) => (
        <div class="card rounded-xl p-6">
          <div class="flex items-start gap-3">
            <span class="shrink-0 mt-0.5" aria-hidden="true" set:html={section.icon} />
            <div>
              <h3 class="text-sm font-semibold mb-2 text-[var(--ot-text-primary)]">
                {section.title}
              </h3>
              <p class="text-xs text-[var(--ot-text-secondary)] leading-relaxed">
                {section.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-[var(--ot-text-muted)] text-center mt-10 max-w-2xl mx-auto leading-relaxed">
      {i.legal.disclaimer}
    </p>
  </div>
</section>
