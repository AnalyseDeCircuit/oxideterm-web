---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";
import { icon } from "@/lib/icons";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const accent = "var(--ot-accent)";
const highlights = [
  { icon: icon("building", { stroke: accent }), title: i.tech.dual_plane, desc: i.tech.dual_plane_desc },
  { icon: icon("monitor", { stroke: accent }), title: i.tech.webgl, desc: i.tech.webgl_desc },
  { icon: icon("link", { stroke: accent }), title: i.tech.pool, desc: i.tech.pool_desc },
  { icon: icon("lock", { stroke: accent }), title: i.tech.encryption, desc: i.tech.encryption_desc },
  { icon: icon("globe", { stroke: accent }), title: i.tech.i18n, desc: i.tech.i18n_desc },
  { icon: icon("wrench", { stroke: accent }), title: i.tech.plugin, desc: i.tech.plugin_desc },
];
---

<section class="py-20 px-6 bg-[var(--ot-bg-deep)] border-t border-[var(--ot-border)]">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-14 tracking-tight">
      {i.tech.title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {highlights.map((item) => (
        <div class="group">
          <div class="mb-3" set:html={item.icon} />
          <h3 class="text-lg font-semibold mb-2 text-[var(--ot-text-primary)] group-hover:text-[var(--ot-accent)] transition-colors">
            {item.title}
          </h3>
          <p class="text-sm text-[var(--ot-text-secondary)] leading-relaxed">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
