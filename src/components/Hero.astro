---
import type { LangKey } from "@/i18n";
import { t, docsPath } from "@/i18n";
import { OXIDETERM_VERSION } from "@/consts";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);
const version = OXIDETERM_VERSION;

// Fetch GitHub stars at build time
let stars = '';
try {
  const res = await fetch('https://api.github.com/repos/AnalyseDeCircuit/oxideterm');
  if (res.ok) {
    const data = await res.json();
    const count = data.stargazers_count;
    if (count >= 1000) {
      stars = `${(count / 1000).toFixed(1)}k`;
    } else if (count > 0) {
      stars = String(count);
    }
  }
} catch {}
---

<section class="relative py-24 md:py-32 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Text content -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs bg-[var(--ot-bg-elevated)] border border-[var(--ot-border)] text-[var(--ot-text-secondary)]" style={`font-family: var(--font-mono);`}>
            {i.hero.version_prefix}{version}
          </span>
          <span class="text-xs text-[var(--ot-text-muted)]">macOS · Windows · Linux</span>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 leading-tight">
          <span class="text-[var(--ot-text-primary)]">Oxide</span><span class="text-[var(--ot-accent)]">Term</span>
        </h1>

        <p class="text-lg md:text-xl text-[var(--ot-text-secondary)] mb-3 leading-relaxed" style={`font-family: var(--font-mono); font-size: 0.95rem;`}>
          {i.hero.tagline}
        </p>

        <p class="text-base text-[var(--ot-text-muted)] mb-8 leading-relaxed max-w-lg">
          {i.hero.subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-start gap-3 mb-6">
          <a
            href="https://github.com/AnalyseDeCircuit/oxideterm/releases/latest"
            class="cta-primary inline-flex items-center gap-2 px-7 py-3 rounded-lg font-semibold"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            {i.hero.cta_download}
          </a>
          <a
            href={docsPath(lang)}
            class="cta-secondary inline-flex items-center gap-2 px-7 py-3 rounded-lg font-semibold"
          >
            {i.hero.cta_docs}
          </a>
        </div>

        <div class="flex items-center gap-4">
          <a
            href="https://github.com/AnalyseDeCircuit/oxideterm"
            class="inline-flex items-center gap-1.5 text-sm text-[var(--ot-text-muted)] hover:text-[var(--ot-accent)] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            {i.hero.source_badge}
          </a>
          {stars && (
            <a
              href="https://github.com/AnalyseDeCircuit/oxideterm/stargazers"
              class="inline-flex items-center gap-1 text-sm text-[var(--ot-text-muted)] hover:text-[var(--ot-accent)] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="var(--ot-accent)" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span>{stars}</span>
            </a>
          )}
        </div>
      </div>

      <!-- Right: Terminal mockup -->
      <div class="terminal-mockup">
        <div class="terminal-titlebar" aria-hidden="true">
          <span class="terminal-dot terminal-dot-red"></span>
          <span class="terminal-dot terminal-dot-yellow"></span>
          <span class="terminal-dot terminal-dot-green"></span>
          <span class="terminal-titlebar-text">OxideTerm — prod-server</span>
        </div>
        <div class="terminal-body">
          <div><span class="terminal-prompt">$</span> ssh prod-server</div>
          <div class="terminal-success">&#10003; Connected (Ed25519 · ChaCha20-Poly1305)</div>
          <div class="terminal-info">Multiplexing: terminal + SFTP + 2 forwards</div>
          <div class="terminal-info">Grace Period: enabled (30s)</div>
          <div>&nbsp;</div>
          <div><span class="terminal-prompt">root@prod-server:~$</span> uptime</div>
          <div class="terminal-dim"> 14:23:01 up 127 days, 3:42, 1 user, load average: <span class="terminal-success">0.12</span>, 0.08, 0.05</div>
          <div>&nbsp;</div>
          <div><span class="terminal-prompt">root@prod-server:~$</span> <span class="cursor-blink">&#9608;</span></div>
        </div>
      </div>
    </div>
  </div>
</section>
