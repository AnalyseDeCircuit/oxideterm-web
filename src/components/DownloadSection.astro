---
import type { LangKey } from "@/i18n";
import { t } from "@/i18n";

interface Props {
  lang: LangKey;
}

const { lang } = Astro.props;
const i = t(lang);

const platforms = [
  {
    name: i.download.macos,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
    variants: [
      { label: i.download.apple_silicon, arch: "aarch64" },
      { label: i.download.intel, arch: "x64" },
    ],
  },
  {
    name: i.download.windows,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5.548l7.206-1.007v6.96H3V5.548zm0 12.904l7.206 1.007V12.5H3v5.952zM11.206 4.36L22 2.5v9H11.206V4.36zm0 15.28L22 21.5v-9H11.206v7.14z"/></svg>`,
    variants: [
      { label: i.download.x64, arch: "x64" },
      { label: i.download.arm64, arch: "arm64" },
    ],
  },
  {
    name: i.download.linux,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.345 1.884 1.345.09 0 .18-.006.264-.018l.004-.003a.283.283 0 00.08-.002c.65-.078 1.33-.467 1.886-.867.248-.178.503-.36.715-.536.322-.33.56-.614.55-.88-.005-.14-.05-.263-.144-.35-.078-.073-.186-.11-.3-.122-.21-.02-.47.05-.56.081-.14.04-.31.08-.44.1a1.37 1.37 0 01-.257.02c-.113-.006-.23-.03-.303-.116v-.004c-.038-.046-.06-.1-.06-.18l.002-.003c.04-.54.56-1.12.86-1.65.16-.27.26-.52.3-.81.02-.14.03-.28.03-.44l.01-.2c.01-.3-.06-.6-.19-.87-.13-.27-.32-.49-.56-.66-.24-.17-.53-.27-.84-.27-.06 0-.12 0-.18.01h-.03c-.12.01-.27.04-.49.04-.26 0-.57-.04-.9-.11-.04-.01-.09-.02-.14-.03-.49-.12-.94-.3-1.35-.55a3.01 3.01 0 01-.73-.61l-.07-.09-.02-.03c-.37-.55-.65-1.1-.82-1.6-.16-.5-.22-1.04-.12-1.7.11-.66.35-1.03.66-1.5.31-.47.74-1.03 1.04-2.04.31-1.04.32-2.37 0-3.57-.3-1.15-.83-1.94-1.47-2.52a5.3 5.3 0 00-1.82-1.09 5.02 5.02 0 00-1.34-.32C12.744.007 12.62 0 12.504 0z"/></svg>`,
    variants: [
      { label: i.download.x64, arch: "x64" },
      { label: i.download.arm64, arch: "arm64" },
    ],
  },
];
---

<section id="download" class="py-20 px-6 border-t border-[var(--ot-border)]">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight">
      {i.download.title}
    </h2>
    <p class="text-[var(--ot-text-secondary)] mb-12">
      {i.download.subtitle}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {platforms.map((platform) => (
        <div class="card rounded-xl p-6 text-center">
          <div class="flex justify-center mb-4 text-[var(--ot-text-secondary)]" set:html={platform.icon} />
          <h3 class="text-lg font-semibold mb-4">{platform.name}</h3>
          <div class="flex flex-col gap-2">
            {platform.variants.map((v) => (
              <a
                href="https://github.com/AnalyseDeCircuit/oxideterm/releases/latest"
                class="platform-btn inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-[var(--ot-bg-surface)] border border-[var(--ot-border)] text-sm text-[var(--ot-text-secondary)] hover:text-[var(--ot-text-primary)] hover:border-[var(--ot-accent)]"
              >
                {v.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <a
      href="https://github.com/AnalyseDeCircuit/oxideterm/releases"
      class="text-sm text-[var(--ot-text-muted)] hover:text-[var(--ot-accent)] transition-colors"
    >
      {i.download.all_releases} →
    </a>
  </div>
</section>
